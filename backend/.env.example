# TMDB API key — REQUIRED (get one at https://www.themoviedb.org/settings/api)
TMDB_API_KEY=your_tmdb_api_key_here

# CORS: extra origins (comma-separated). Production Netlify URLs are already hardcoded.
# For preview URLs add them here, e.g.: FRONTEND_ORIGINS=https://deploy-preview-42--movieswrapped.netlify.app
FRONTEND_ORIGINS=

# Supabase (anon/public key only — never service_role)
# New project: https://ghumergebwwrwlykwjsu.supabase.co
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_OPS_EMAIL=ops@movieswrapped.internal
SUPABASE_OPS_PASSWORD=
RUN_RETENTION_DAYS=30

# Desktop worker auth — shared secret between backend and desktop worker
# Must match the value in the desktop's .env
WORKER_TOKEN=
WORKER_TOKEN_PREVIOUS=
# Backend URL the desktop worker polls (Render production URL)
WORKER_BACKEND_URL=https://wrapped-backend.onrender.com

# Optional: desktop worker startup smoke test (opt-in — scrapes Letterboxd)
WORKER_SELF_TEST_ON_START=0
WORKER_SELF_TEST_USERNAME=semihmutsuz

# Optional: Sentry error tracking
SENTRY_DSN=

# WARNING: Do NOT set SCRAPER_API_KEY — the system uses direct cloudscraper
# scraping from the desktop worker's residential IP.

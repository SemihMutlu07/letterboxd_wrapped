{
  "openapi": "3.1.0",
  "info": {
    "title": "Letterboxd Wrapped API",
    "description": "Analyze Letterboxd exports and generate wrapped-style film statistics.",
    "version": "2.0.0"
  },
  "paths": {
    "/api/analyze": {
      "post": {
        "summary": "Analyze Data",
        "description": "Accept a Letterboxd export (ZIP or CSVs) and start analysis in the background.\nReturns 202 Accepted with a task_id for polling.",
        "operationId": "analyze_data_api_analyze_post",
        "requestBody": {
          "content": {
            "multipart/form-data": {
              "schema": {
                "$ref": "#/components/schemas/Body_analyze_data_api_analyze_post"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/progress/{task_id}": {
      "get": {
        "summary": "Get Task Progress",
        "description": "Poll analysis progress and retrieve the final result when done.",
        "operationId": "get_task_progress_api_progress__task_id__get",
        "parameters": [
          {
            "name": "task_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Task Id"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/progress": {
      "get": {
        "summary": "Get Progress Legacy",
        "description": "Legacy progress endpoint \u2014 returns the most recent active task state.",
        "operationId": "get_progress_legacy_api_progress_get",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/tmdb/person/search": {
      "get": {
        "summary": "Search Tmdb Person",
        "description": "Search TMDB for a person and return their profile image URL.",
        "operationId": "search_tmdb_person_api_tmdb_person_search_get",
        "parameters": [
          {
            "name": "name",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Name"
            }
          },
          {
            "name": "role",
            "in": "query",
            "required": false,
            "schema": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "null"
                }
              ],
              "title": "Role"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/tmdb-proxy/{path}": {
      "get": {
        "summary": "Tmdb Proxy",
        "description": "Proxy TMDB images to avoid CORS issues.",
        "operationId": "tmdb_proxy_tmdb_proxy__path__get",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Path"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      },
      "options": {
        "summary": "Tmdb Proxy Options",
        "description": "Handle CORS preflight for TMDB proxy.",
        "operationId": "tmdb_proxy_options_tmdb_proxy__path__options",
        "parameters": [
          {
            "name": "path",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Path"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/api/parse-username": {
      "post": {
        "summary": "Parse Username",
        "description": "Parse a Letterboxd username from an export filename.",
        "operationId": "parse_username_api_parse_username_post",
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {}
              }
            }
          }
        }
      }
    },
    "/api/feedback": {
